generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model document {
  parent_item_id Int
  id             Int    @id @default(autoincrement())
  file_url       String
  file_type      String @db.VarChar(50)
  file_size      Int
  item           item   @relation(fields: [parent_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model item {
  owner_id          Int?
  id                Int              @id @default(autoincrement())
  title             String           @db.VarChar(255)
  cover_image       String?
  description       String?
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?        @db.Timestamptz(6)
  parent_collection Int?
  document          document[]
  users             users?           @relation(fields: [owner_id], references: [id], onUpdate: NoAction)
  item_collection   item_collection? @relation(fields: [parent_collection], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model item_collection {
  owner_id              Int?
  id                    Int               @id @default(autoincrement())
  title                 String            @db.VarChar(255)
  parent_collection     Int?
  item                  item[]
  users                 users?            @relation(fields: [owner_id], references: [id], onUpdate: NoAction)
  item_collection       item_collection?  @relation("item_collectionToitem_collection", fields: [parent_collection], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_item_collection item_collection[] @relation("item_collectionToitem_collection")
}

model users {
  id              Int               @id @default(autoincrement())
  name            String            @unique @db.VarChar(255)
  password        String
  avatar          String?
  email           String?           @unique @db.VarChar(255)
  phone           String?           @unique @db.VarChar(20)
  birthday        DateTime?         @db.Date
  role            user_role
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  item            item[]
  item_collection item_collection[]
}

enum user_role {
  admin
  editor
  viewer
}
